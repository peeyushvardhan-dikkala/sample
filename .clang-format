# .clang-format
# VS Code (put in settings.json)
# Press Ctrl + Shift + P
# Type: Preferences: Open User Settings (JSON)
# "C_Cpp.clang_format_style": "file",
# "C_Cpp.formatting": "clangFormat"

BasedOnStyle: LLVM
IndentWidth: 4
UseTab: Never

PointerAlignment: Left

SpacesInParentheses: false
SpaceBeforeParens: ControlStatements
SpaceBeforeAssignmentOperators: true
SpaceBeforeBinaryOperators: All

IndentAccessModifiers: false
AccessModifierOffset: -4

AllowShortIfStatementsOnASingleLine: false

SortIncludes: true

BreakBeforeBraces: Attach
BraceWrapping:
  AfterControlStatement: false
  AfterFunction: false
  AfterClass: false
  AfterNamespace: false
  AfterStruct: false
  AfterEnum: false
  BeforeElse: false

Cpp11BracedListStyle: true

# ==========================
# Additional Notes / Commands
# ==========================
# Format full file in terminal:
#   clang-format -i your_file.cpp
#
# Format specific lines in terminal:
#   clang-format -i -lines=start:end your_file.cpp
#
# Rename .clang-format file in Windows (if downloaded as .txt):
#   ren ".clang-format.txt" ".clang-format"
#
# VS Code settings (if you want to hardcode style):
# Ctrl + Shift + P → C/C++: Edit Configurations (UI)
#   "[cpp]": {
#       "editor.defaultFormatter": "ms-vscode.cpptools",
#       "editor.formatOnSave": true
#   },
#   "C_Cpp.clang_format_style": "file"
#
# Or single-line hardcoded style in settings.json:
#   "C_Cpp.clang_format_style": "{ \"BasedOnStyle\": \"LLVM\", \"IndentWidth\": 4, \"UseTab\": \"Never\", \"PointerAlignment\": \"Left\", \"SpacesInParentheses\": false, \"SpaceBeforeParens\": \"ControlStatements\", \"SpaceBeforeAssignmentOperators\": true, \"SpaceBeforeBinaryOperators\": \"All\", \"IndentAccessModifiers\": false, \"AccessModifierOffset\": -4, \"AllowShortIfStatementsOnASingleLine\": false, \"SortIncludes\": true, \"BreakBeforeBraces\": \"Attach\", \"BraceWrapping\": { \"AfterControlStatement\": false, \"AfterFunction\": false, \"AfterClass\": false, \"AfterNamespace\": false, \"AfterStruct\": false, \"AfterEnum\": false, \"BeforeElse\": false }, \"Cpp11BracedListStyle\": true }"
# VS Code formatting shortcut: Shift + Alt + F
# Best practice: keep .clang-format in project root for consistent team formatting
