// 21. Group Anagrams
#include <algorithm>
#include <iostream>
#include <string>
#include <unordered_map>
#include <vector>
using namespace std;

int main() {
    // Input words
    vector<string> words = {"eat", "tea", "tan", "ate", "nat", "bat"};

    // Step 1: Group anagrams using a sorted key

    unordered_map<string, vector<string>> groups;

    for (string word : words) {
        string key = word;            // copy original
        sort(key.begin(), key.end()); // sorted version becomes key
        groups[key].push_back(word);  // group by sorted key
    }

    // Step 2: Move all groups into a vector
    vector<vector<string>> result;
    for (auto& entry : groups) {
        // optional: sort words inside each group alphabetically
        // sort(entry.second.begin(), entry.second.end());
        result.push_back(entry.second);
    }

    // Step 3: Sort groups by size (larger groups first)
    sort(result.begin(), result.end(),
         [](const vector<string>& a, const vector<string>& b) {
             return a.size() > b.size(); // descending order
         });

    // Step 4: Print grouped anagrams
    cout << "Grouped Anagrams (sorted by group size):\n";
    for (auto& group : result) {
        cout << "[ ";
        for (auto& word : group)
            cout << word << " ";
        cout << "]\n";
    }

    return 0;
}


// 22.Replace a Whole Word in a String Without Affecting Substrings
#include<iostream>
#include<string>    
using namespace std;

int main() {
    string s = "This is Peeyush";
    string s1 = "is";
    size_t pos = 0;
    while((pos=s.find(s1,pos))!=string::npos) {
        bool isLeftOk = (pos == 0 || s[pos - 1] == ' ');
        bool isRightOk = (pos + s1.length() == s.length() || s[pos + s1.length()] == ' ');
        if (isLeftOk && isRightOk) {
            s.replace(pos, s1.length(), "was");
            pos += 3; // move past "was"
        } else {
            pos += s1.length();
        }
    }
    std::cout << s;
}
