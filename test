#include<iostream>
using namespace std;

struct Node {
    int data;
    Node* next;

    Node(int val):data(val),next(nullptr) {}
};

class Linkedlist {
    public:
        Node* head = nullptr;
        Linkedlist(): head(nullptr) {}
    
    void insertAtBeginning(int val) {
        Node* newNode = new Node(val);
        newNode->next = head;
        head = newNode;
    }

    void insertAtEnd(int val) {
        Node* newNode = new Node(val);
        if(head==nullptr) {
            head = newNode;
            return;
        }
        Node* temp = head;

        while(temp->next!=nullptr) {
            temp = temp->next;
        }
        temp->next = newNode;
    }

    void insertAtPosition(int val, int pos) {
        if(pos<=0)
            return;

        if(pos==1) {
            Node* newNode = new Node(val);
            newNode->next = head;
            head = newNode;
            return;
        }

        Node* temp = head;
        for (int i = 1; i < pos - 1 && temp != nullptr;i++) {
            temp = temp->next;
        }

        if(temp==nullptr)
            return;
        Node* newNode = new Node(val);
        newNode->next = temp->next;
        temp->next = newNode;
    }

    void deleteAtBeginning() {
        if(head==nullptr)
            return;

        Node* delNode = head;
        head = head->next;
        delete delNode;
    }

    void deleteAtEnding() {
        if(head==nullptr)
            return;
        
        if(head->next==nullptr) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        while(temp->next->next!=nullptr) {
            temp = temp->next;
        }

        delete temp->next;
        temp->next = nullptr;
    }

    void deleteAtPosition(int pos) {
        if(head==nullptr)
            return;
        
        if(pos<=0)
            return;
        
        if(pos==1) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        for (int i = 1; i < pos - 1 && temp != nullptr;i++) {
            temp = temp->next;
        }

        if(temp->next==nullptr || temp == nullptr)
            return;

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
        delNode = nullptr;
    }

    void deleteByVal(int val) {
        if(head==nullptr)
            return;
        
        if(head->data==val) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        while(temp->next!=nullptr&&temp->next->data!=val) {
            temp = temp->next;
        }

        if(temp->next==nullptr)
            return;

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
    }

    void display() {
        Node* temp = head;
        
        while(temp!=nullptr) {
            cout << temp->data<<" -> ";
            temp = temp->next;
        }

        cout << "NULL\n";
    }

    void reverseLinkedlist(Node* head) {
        Node* temp = head;
        Node* prev = nullptr;
        Node* front = nullptr;

        while(temp!=nullptr) {
            front = temp->next;
            temp->next = prev;

            prev = temp;
            temp = front;
        }
        head=prev;
    }

    void recursivereverseLinkedlist(Node* node) {
        // Base case: empty list OR last node
        if (node == nullptr || node->next == nullptr) {
            head = node;  // update head to last node
            return;
        }
    
        // Recursive call
        recursivereverseLinkedlist(node->next);
    
        // Reverse the link
        node->next->next = node;
    
        // Break the forward link
        node->next = nullptr;
    }

    void deleteMiddleNode() {
        if(head==nullptr)
            return;
        if(head->next==nullptr) {
            delete head;
            head = nullptr;
            return;
        }
        Node* slow = head;
        Node* fast = head->next->next; // First Middle
        // Node* fast= head->next; // Second Middle

        while(fast!=nullptr && fast->next!=nullptr) {
            slow = slow->next;
            fast = fast->next->next;
        }

        Node* delNode = slow->next;
        slow->next = delNode->next;
        delete delNode;
    }

    Node* printReverseLinkedList(Node* head) {
        if(head==nullptr)
            return;

        Node* temp = printReverseLinkedList(head->next);
        cout << temp->data << "->";
    }

    void reverse() {
        head = printReverseLinkedList(head);
    }

    bool isPalindrome(Node* head) {
        if (head == NULL || head->next == NULL)
            return true;
    
        Node* slow = head;
        Node* fast = head;
    
        // Find middle
        while (fast->next != NULL && fast->next->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;
        }
    
        // Reverse second half
        Node* secondHalf = reverseLinkedList(slow->next);
    
        Node* first = head;
        Node* second = secondHalf;
    
        // Compare
        while (second != NULL) {
            if (first->data != second->data) {
                // Restore before returning
                slow->next = reverseLinkedList(secondHalf);
                return false;
            }
            first = first->next;
            second = second->next;
        }
    
        // Restore list
        slow->next = reverseLinkedList(secondHalf);
    
        return true;
    }
};

int main() {
    Linkedlist ll;
    ll.insertAtEnd(4);
    ll.insertAtEnd(8);
    ll.insertAtEnd(7);
    ll.display();
    ll.deleteMiddleNode();
    ll.display();
}

#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
    Node* prev;

    Node(int val) {
        data = val;
        next = prev = nullptr;
    }
};

class DoubleLinkedlist {
private:
    Node* head = nullptr;
    Node* tail = nullptr;

    public:
    DoubleLinkedlist() { head = tail = nullptr; }

    ~DoubleLinkedlist() {
        Node* temp = head;
        Node* nextNode = nullptr;
        while (temp != nullptr) {
            nextNode = temp->next;
            delete temp;
            temp = nextNode;
        }

        head = tail = nullptr;
    }

    void insertAtBeginning(int val) {
        Node* newNode = new Node(val);

        if (head == nullptr) {
            head = tail = newNode;
            return;
        }

        newNode->next = head;
        head->prev = newNode;
        head = newNode;
    }

    void insertAtEnd(int val) {
        Node* newNode = new Node(val);

        if (head == nullptr) {
            head = tail = newNode;
            return;
        }

        tail->next = newNode;
        newNode->prev = tail;
        tail = newNode;
    }

    void insertAtPosition(int pos, int val) {
        if (pos < 1)
            return;
        
        if (pos == 1) {
            insertAtBeginning(val);
            return;
        }

        Node* curr = head;
        for (int i = 1; i < pos-1 && curr; i++) {
            curr = curr->next;
        }

        if(!curr)
            return;

        if (curr == tail) {
            insertAtEnd(val);
            return;
        }
    
        Node* newNode = new Node(val);
        newNode->prev = curr;
        newNode->next = curr->next;

        curr->next->prev = newNode;
        curr->next = newNode;
    }

    void deleteAtBeginning() {
        if (head == nullptr)
            return;

        if (head == tail) {
            delete head;
            head = tail = nullptr;
            return;
        }

        Node* delNode = head;
        head = head->next;
        head->prev = nullptr;
        delete delNode;
    }

    void deleteAtEnd() {
        if (head == nullptr)
            return;

        if (head == tail) {
            delete head;
            head = tail = nullptr;
            return;
        }

        Node* delNode = tail;
        tail = tail->prev;
        tail->next = nullptr;
        delete delNode;
    }

    void deleteByPosition(int pos) {
        if (pos < 1)
            return;

        if (pos == 1) {
            deleteAtBeginning();
            return;
        }

        Node* curr = head;
        Node* prevNode = nullptr;

        for (int i = 1; i < pos && curr; i++) {
            prevNode = curr;
            curr = curr->next;
        }

        if(!curr)
            return;

        if (curr == tail) {
            deleteAtEnd();
            return;
        }

        prevNode->next = curr->next;
        curr->next->prev = prevNode;

        delete curr;
    }

    void deleteByValue(int val) {
        if (!head)
            return;
    
        Node* curr = head;
    
        while (curr && curr->data != val) {
            curr = curr->next;
        }
    
        if (!curr)
            return;
    
        if (curr == head) {
            deleteAtBeginning();
            return;
        }
    
        if (curr == tail) {
            deleteAtEnd();
            return;
        }
    
        curr->prev->next = curr->next;
        curr->next->prev = curr->prev;
    
        delete curr;
    }

    void deleteAtMiddleNode() {
        if (!head) 
            return;
    
        if (head == tail) {
            delete head;
            head = tail = nullptr;
            return;
        }
    
        Node* slow = head;
        Node* fast = head;
        // fast = head->next; for first middle
        Node* prevNode = nullptr;
    
        while (fast && fast->next) {
            prevNode = slow;
            slow = slow->next;
            fast = fast->next->next;
        }
        // prevNode == NULL → deleting head
        // slow->next == NULL → deleting tail
        // For 1 -> 2 node
        if (prevNode)
            prevNode->next = slow->next;
        else
            head = slow->next;
    
        if (slow->next)
            slow->next->prev = prevNode;
        else
            tail = prevNode;

        delete slow;
    }

    void print() {
        if (!head) {
            cout << "EMPTY\n";
            return;
        }

        Node* temp = head;
        while(temp!=nullptr) {
            cout << temp->data << " -> ";
            temp = temp->next;
        }

        cout << "NULL\n";
    }

    void reverse() {
        Node* curr = head;
        Node* temp = nullptr;
    
        while (curr) {
            // swap prev and next
            temp = curr->prev;
            curr->prev = curr->next;
            curr->next = temp;
    
            // move to "next" node (which is prev now)
            curr = curr->prev;
        }
    
        // swap head and tail
        temp = head;
        head = tail;
        tail = temp;
    }
};

int main() {
    DoubleLinkedlist dll;

    dll.insertAtEnd(5);
    dll.insertAtEnd(10);
    dll.insertAtEnd(15);

    dll.print();

    dll.insertAtBeginning(2);
    dll.insertAtBeginning(1);
    dll.print();

    dll.deleteAtBeginning();
    dll.print();

    dll.deleteAtEnd();
    dll.print();

    dll.deleteByPosition(1);
    dll.print();

    dll.deleteByValue(10);
    dll.print();

    dll.deleteAtMiddleNode();
    dll.print();
}

// Circular Linked List
#include<iostream>
using namespace std;

struct Node{
    int data;
    Node* next;

    Node(int val) {
        data = val;
        next = nullptr;
    }
};

class CircularLinkedlist {
    private:
    Node* head = nullptr;
    Node* tail = nullptr;

public:
    CircularLinkedlist() : head(nullptr), tail(nullptr) {}

    ~CircularLinkedlist() {
        if (head == nullptr)
            return;
    
        Node* curr = head->next;
    
        while (curr != head) {
            Node* temp = curr;
            curr = curr->next;
            delete temp;
        }
    
        delete head;
        head = nullptr;
    }
    void insertAtBeginning(int val) {
        Node* newNode = new Node(val);
        if (head == nullptr) {
            newNode->next = newNode;
            head = tail = newNode;
            return;
        }
        newNode->next = head;
        tail->next = newNode;
        head = newNode;
    }

    void insertAtEnd(int val) {
        Node* newNode = new Node(val);
        if (head == nullptr) {
            newNode->next = newNode;
            head = tail=newNode;
            return;
        }

        tail->next = newNode;
        newNode->next = head;
        tail = newNode;
    }

    int countNodes() {
        if (head == nullptr)
            return 0;

        Node* temp = head;
        int n = 0;
        do {
            n++;
            temp = temp->next;
        } while (temp != head);
        return n;
    }   

    void insertAtPosition(int pos, int val) {
        int n = countNodes();

        if (pos < 1 || pos > n + 1) {
            return;
        }

        if (head == nullptr && pos == 1) {
            insertAtBeginning(val);
            return;
        }

        if (pos == n + 1) {
            insertAtEnd(val);
            return;
        }
        Node* temp = head;
        for (int i = 1; i < pos - 1; i++) {
            temp = temp->next;
        }

        Node* newNode = new Node(val);
        newNode->next = temp->next;
        temp->next = newNode;     
    }

    void deleteAtBeginning() {
        if (head == nullptr)
            return;

        if (tail == head) {
            delete head;
            head = nullptr;
            return;
        }

        Node* delNode = head;
        head = head->next;
        tail->next = head;
        delete delNode;
    }

    void deleteAtEnd() {
        if (head == nullptr)
            return;

        if (head->next == head) {
            delete head;
            head = tail=nullptr;
            return;
        }

        Node* temp = head;
        while (temp->next->next != head) {
            temp = temp->next;
        }

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
        tail = temp;
    }

    void deleteAtPosition(int pos) {
        int n = countNodes();

        if (pos < 1 || head == nullptr || pos > n) {
            return;
        }

        if (pos == 1) {
            deleteAtBeginning();
            return;
        }

        if (pos == n) {
            deleteAtEnd();
            return;
        }

        Node* temp = head;
        for (int i = 1; i < pos - 1; i++) {
            temp = temp->next;
        }

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
    }

    void deleteAtValue(int val) {
        if(head==nullptr)
            return;

        if (head->data == val) {
            deleteAtBeginning();
            return;
        }

        Node* temp = head;
        bool found = false;
        while (temp->next != head) {
            if (temp->next->data == val) {
                Node* delNode = temp->next;
                temp->next = delNode->next;
                delete delNode;
                found = true;
                return;
            }
            temp = temp->next;
        }
        
        if (!found) {
            cout << "Value not found\n";
        }
    }

    void reverseCircularLinkedlist() {
        if (head == nullptr || head->next == head)
            return;

        Node* temp = head;
        Node* front = nullptr;
        Node* prev = nullptr;

        do {
            front = temp->next;
            temp->next = prev;
            prev = temp;
            temp = front;
        } while (temp != head);

        head->next = prev;
        head = prev;
        tail = temp;
    }

    void print() {
        if (head == nullptr)
            return;

        Node* temp = head;
        do {
            cout << temp->data << " -> ";
            temp = temp->next;
        } while (temp != head);
        cout <<"(head)"<<endl;
    }
};

int main() {
    CircularLinkedlist cll;
    cll.insertAtEnd(5);
    cll.insertAtEnd(10);
    cll.insertAtEnd(15);
    cll.print();
    cll.insertAtBeginning(2);
    cll.print();
    cll.reverseCircularLinkedlist();
    cll.print();
}
