#include<iostream>
using namespace std;

struct Node {
    int data;
    Node* next;

    Node(int val):data(val),next(nullptr) {}
};

class Linkedlist {
    public:
        Node* head = nullptr;
        Linkedlist(): head(nullptr) {}
    
    void insertAtBeginning(int val) {
        Node* newNode = new Node(val);
        newNode->next = head;
        head = newNode;
    }

    void insertAtEnd(int val) {
        Node* newNode = new Node(val);
        if(head==nullptr) {
            head = newNode;
            return;
        }
        Node* temp = head;

        while(temp->next!=nullptr) {
            temp = temp->next;
        }
        temp->next = newNode;
    }

    void insertAtPosition(int val, int pos) {
        if(pos<=0)
            return;

        if(pos==1) {
            Node* newNode = new Node(val);
            newNode->next = head;
            head = newNode;
            return;
        }

        Node* temp = head;
        for (int i = 1; i < pos - 1 && temp != nullptr;i++) {
            temp = temp->next;
        }

        if(temp==nullptr)
            return;
        Node* newNode = new Node(val);
        newNode->next = temp->next;
        temp->next = newNode;
    }

    void deleteAtBeginning() {
        if(head==nullptr)
            return;

        Node* delNode = head;
        head = head->next;
        delete delNode;
    }

    void deleteAtEnding() {
        if(head==nullptr)
            return;
        
        if(head->next==nullptr) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        while(temp->next->next!=nullptr) {
            temp = temp->next;
        }

        delete temp->next;
        temp->next = nullptr;
    }

    void deleteAtPosition(int pos) {
        if(head==nullptr)
            return;
        
        if(pos<=0)
            return;
        
        if(pos==1) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        for (int i = 1; i < pos - 1 && temp != nullptr;i++) {
            temp = temp->next;
        }

        if(temp->next==nullptr || temp == nullptr)
            return;

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
        delNode = nullptr;
    }

    void deleteByVal(int val) {
        if(head==nullptr)
            return;
        
        if(head->data==val) {
            Node* delNode = head;
            head = head->next;
            delete delNode;
            return;
        }

        Node* temp = head;
        while(temp->next!=nullptr&&temp->next->data!=val) {
            temp = temp->next;
        }

        if(temp->next==nullptr)
            return;

        Node* delNode = temp->next;
        temp->next = delNode->next;
        delete delNode;
    }

    void display() {
        Node* temp = head;
        
        while(temp!=nullptr) {
            cout << temp->data<<" -> ";
            temp = temp->next;
        }

        cout << "NULL\n";
    }

    void reverseLinkedlist(Node* head) {
        Node* temp = head;
        Node* prev = nullptr;
        Node* front = nullptr;

        while(temp!=nullptr) {
            front = temp->next;
            temp->next = prev;

            prev = temp;
            temp = front;
        }
        head=prev;
    }

    void recursivereverseLinkedlist(Node* node) {
        // Base case: empty list OR last node
        if (node == nullptr || node->next == nullptr) {
            head = node;  // update head to last node
            return;
        }
    
        // Recursive call
        recursivereverseLinkedlist(node->next);
    
        // Reverse the link
        node->next->next = node;
    
        // Break the forward link
        node->next = nullptr;
    }

    void deleteMiddleNode() {
        if(head==nullptr)
            return;
        if(head->next==nullptr) {
            delete head;
            head = nullptr;
            return;
        }
        Node* slow = head;
        Node* fast = head->next->next; // First Middle
        // Node* fast= head->next; // Second Middle

        while(fast!=nullptr && fast->next!=nullptr) {
            slow = slow->next;
            fast = fast->next->next;
        }

        Node* delNode = slow->next;
        slow->next = delNode->next;
        delete delNode;
    }

    Node* printReverseLinkedList(Node* head) {
        if(head==nullptr)
            return;

        Node* temp = printReverseLinkedList(head->next);
        cout << temp->data << "->";
    }

    void reverse() {
        head = printReverseLinkedList(head);
    }

    bool isPalindrome(Node* head) {
        if (head == NULL || head->next == NULL)
            return true;
    
        Node* slow = head;
        Node* fast = head;
    
        // Find middle
        while (fast->next != NULL && fast->next->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;
        }
    
        // Reverse second half
        Node* secondHalf = reverseLinkedList(slow->next);
    
        Node* first = head;
        Node* second = secondHalf;
    
        // Compare
        while (second != NULL) {
            if (first->data != second->data) {
                // Restore before returning
                slow->next = reverseLinkedList(secondHalf);
                return false;
            }
            first = first->next;
            second = second->next;
        }
    
        // Restore list
        slow->next = reverseLinkedList(secondHalf);
    
        return true;
    }
};

int main() {
    Linkedlist ll;
    ll.insertAtEnd(4);
    ll.insertAtEnd(8);
    ll.insertAtEnd(7);
    ll.display();
    ll.deleteMiddleNode();
    ll.display();
}
